<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="joe" params="prefix parent *origin">
    <!-- LINKS -->
    <link name="${prefix}base_footprint"/>

    <!-- base link -->
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
        <mass value="26.6"/>
        <inertia ixx="0.387" ixy="0" ixz="0" iyy="0.790" iyz="0" izz="0.962"/>
      </inertial>

      <!-- collisions -->
      <collision name="chassis_main_collision">
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
        <geometry>
          <box size="0.38 0.3 0.13"/>
        </geometry>
      </collision>
      <collision name="front_left_wheel_mount_collision">
        <origin xyz="0.17 0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
      </collision>
      <collision name="front_right_wheel_mount_collision">
        <origin xyz="0.17 -0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
      </collision>
      <collision name="rear_left_wheel_mount_collision">
        <origin xyz="-0.17 0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
      </collision>
      <collision name="rear_right_wheel_mount_collision">
        <origin xyz="-0.17 -0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
      </collision>
      <collision name="emergency_stop_bottom_collision">
        <origin xyz="0.11 0.125 0.145" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.015"/>
        </geometry>
      </collision>
      <collision name="emergency_stop_top_collision">
        <origin xyz="0.11 0.125 0.155" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.005"/>
        </geometry>
      </collision>
      <collision name="sensor_upper_deck_collision">
        <origin xyz="0 0 0.435" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.01"/>
        </geometry>
      </collision>
      <collision name="sensor_mid_deck_collision">
        <origin xyz="0 0 0.325" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.01"/>
        </geometry>
      </collision>
      <collision name="sensor_lower_deck_collision">
        <origin xyz="0 0 0.135" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.01"/>
        </geometry>
      </collision>
      <collision name="beam1_collision">
        <origin xyz="0.091 0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
      </collision>
      <collision name="beam2_collision">
        <origin xyz="0.091 -0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
      </collision>
      <collision name="beam3_collision">
        <origin xyz="-0.091 0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
      </collision>
      <collision name="beam4_collision">
        <origin xyz="-0.091 -0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
      </collision>
      <collision name="sensor_mast_collision">
        <origin xyz="0 0 1.0125" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.03 1.125"/>
        </geometry>
      </collision>
      <collision name="camera_plate_collision">
        <origin xyz="0.035 0 1.525" rpy="0 0 0"/>
        <geometry>
          <box size="0.11 0.12 0.02"/>
        </geometry>
      </collision>
      <collision name="gps_board_collision">
        <origin xyz="0 0 1.57" rpy="0 0 0"/>
        <geometry>
          <box size="0.14 0.10 0.02"/>
        </geometry>
      </collision>

      <!-- visuals -->
      <visual name="chassis_main_visual">
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
        <geometry>
          <box size="0.38 0.3 0.13"/>
        </geometry>
        <material name="chassis_main_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="front_left_wheel_mount_visual">
        <origin xyz="0.17 0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="front_left_wheel_mount_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="front_right_wheel_mount_visual">
        <origin xyz="0.17 -0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="front_right_wheel_mount_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="rear_left_wheel_mount_visual">
        <origin xyz="-0.17 0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="rear_left_wheel_mount_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="rear_right_wheel_mount_visual">
        <origin xyz="-0.17 -0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="rear_right_wheel_mount_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="emergency_stop_bottom_visual">
        <origin xyz="0.11 0.125 0.145" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.015"/>
        </geometry>
        <material name="emergency_stop_bottom_visual_mat">
          <color rgba="0.7059 0.7059 0.7059 1.0"/>
        </material>
      </visual>
      <visual name="emergency_stop_top_visual">
        <origin xyz="0.11 0.125 0.155" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.005"/>
        </geometry>
        <material name="emergency_stop_top_visual_mat">
          <color rgba="1.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <visual name="sensor_upper_deck_visual">
        <origin xyz="0 0 0.435" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.005"/>
        </geometry>
        <material name="sensor_upper_deck_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="sensor_mid_deck_visual">
        <origin xyz="0 0 0.325" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.005"/>
        </geometry>
        <material name="sensor_mid_deck_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="sensor_lower_deck_visual">
        <origin xyz="0 0 0.135" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.005"/>
        </geometry>
        <material name="sensor_lower_deck_visual_mat">
          <color rgba="0.9412 0.9412 0.9412 1.0"/>
        </material>
      </visual>
      <visual name="beam1_visual">
        <origin xyz="0.091 0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="beam2_visual">
        <origin xyz="0.091 -0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="beam3_visual">
        <origin xyz="-0.091 0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam3_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="beam4_visual">
        <origin xyz="-0.091 -0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam4_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="sensor_mast_visual">
        <origin xyz="0 0 1.0125" rpy="0 0 0"/>
        <geometry>
          <box size="0.025 0.025 1.125"/>
        </geometry>
        <material name="sensor_mast_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="camera_plate_visual">
        <origin xyz="0.035 0 1.521" rpy="0 0 0"/>
        <geometry>
          <box size="0.11 0.12 0.012"/>
        </geometry>
        <material name="camera_plate_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="gps_board_visual">
        <origin xyz="0 0 1.57" rpy="0 0 0"/>
        <geometry>
          <box size="0.14 0.10 0.012"/>
        </geometry>
        <material name="gps_board_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
    </link>

    <!-- drive wheels -->
    <link name="${prefix}front_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="front_left_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="-1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="front_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/wheel_left.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="front_left_wheel_axle_visual">
        <origin xyz="0 -0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="front_left_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}front_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="front_right_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="front_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/wheel_right.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="front_right_wheel_axle_visual">
        <origin xyz="0 0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="front_right_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rear_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="rear_left_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="-1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="rear_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/wheel_left.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="rear_left_wheel_axle_visual">
        <origin xyz="0 -0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="rear_left_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rear_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="rear_right_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="rear_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/wheel_right.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="rear_right_wheel_axle_visual">
        <origin xyz="0 0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="rear_right_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <!-- sensor and light frames -->
    <link name="${prefix}imu_sensor_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
    </link>

    <link name="${prefix}gps_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
      <visual name="gps_base_visual">
        <origin xyz="0 0 0.012" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.028" length="0.024"/>
        </geometry>
        <material name="gps_base_visual_mat">
          <color rgba="0.92 0.92 0.92 1.0"/>
        </material>
      </visual>
      <visual name="gps_cap_visual">
        <origin xyz="0 0 0.028" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.016"/>
        </geometry>
        <material name="gps_cap_visual_mat">
          <color rgba="0.96 0.96 0.96 1.0"/>
        </material>
      </visual>
      <visual name="gps_antenna_tip_visual">
        <origin xyz="0 0 0.060" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.0035" length="0.024"/>
        </geometry>
        <material name="gps_antenna_tip_visual_mat">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rgbd_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
      <visual name="d435i_realsense_camera_visual">
        <origin xyz="-0.03 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/realsense_d435.dae" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
    </link>

    <link name="${prefix}lidar_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
      <visual name="vlp16_visual1">
        <origin xyz="0 0 -0.038" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/VLP16_base_1.dae" scale="1 1 1"/>
        </geometry>
      </visual>
      <visual name="vlp16_visual2">
        <origin xyz="0 0 -0.038" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/VLP16_base_2.dae" scale="1 1 1"/>
        </geometry>
      </visual>
      <visual name="vlp16_visual3">
        <origin xyz="0 0 -0.038" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_description/meshes/joe/visual/VLP16_scan.dae" scale="1 1 1"/>
        </geometry>
      </visual>
    </link>

    <!-- JOINTS -->
    <!-- base joints -->
    <xacro:if value="${parent != ''}">
      <joint name="${prefix}base_joint" type="fixed">
        <xacro:insert_block name="origin"/>
        <parent link="${parent}"/>
        <child link="${prefix}base_footprint"/>
      </joint>
    </xacro:if>

    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <parent link="${prefix}base_footprint"/>
      <child link="${prefix}base_link"/>
      <origin xyz="0 0 0.1275" rpy="0 0 0"/>
    </joint>

    <!-- wheel joints -->
    <joint name="${prefix}front_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}front_left_wheel"/>
      <origin xyz="0.17 0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="50" velocity="19.61"/>
    </joint>
    <joint name="${prefix}rear_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}rear_left_wheel"/>
      <origin xyz="-0.17 0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="50" velocity="19.61"/>
    </joint>
    <joint name="${prefix}rear_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}rear_right_wheel"/>
      <origin xyz="-0.17 -0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="50" velocity="19.61"/>
    </joint>
    <joint name="${prefix}front_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}front_right_wheel"/>
      <origin xyz="0.17 -0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="50" velocity="19.61"/>
    </joint>

    <!-- sensor and light frame joints -->
    <joint name="${prefix}base_link_to_imu_sensor_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}imu_sensor_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <joint name="${prefix}base_link_to_gps_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}gps_link"/>
      <origin xyz="0 0 1.58" rpy="0 0 0"/>
    </joint>
    <joint name="${prefix}base_link_to_rgbd_front_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}rgbd_front_link"/>
      <origin xyz="0.11 0 1.5" rpy="0 0.5236 0"/>
    </joint>
    <joint name="${prefix}base_link_to_lidar_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}lidar_link"/>
      <origin xyz="0 0 0.365" rpy="0 0 0"/>
    </joint>
    <!-- GAZEBO EXTENSIONS -->
    <!-- sensor definitions -->
    <gazebo reference="${prefix}imu_sensor_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <topic>imu</topic>
        <imu>
          <enable_orientation>0</enable_orientation>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}gps_link">
      <sensor name="navsat" type="navsat">
        <always_on>1</always_on>
        <update_rate>5</update_rate>
        <topic>navsat</topic>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}rgbd_front_link">
      <sensor name="rgbd_front" type="rgbd_camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <camera name="rgbd_front">
          <horizontal_fov>1.50098</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>343.159</fx>
              <fy>343.159</fy>
              <cx>319.5</cx>
              <cy>179.5</cy>
              <s>0</s>
            </intrinsics>
          </lens>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
            <center>0.5 0.5</center>
          </distortion>
          <image>
            <width>640</width>
            <height>360</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>300</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.1</near>
              <far>10</far>
            </clip>
          </depth_camera>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}lidar_link">
      <sensor name="lidar" type="gpu_lidar">
        <visualize>0</visualize>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>1800</samples>
              <resolution>1</resolution>
              <min_angle>-3.1459</min_angle>
              <max_angle>3.1459</max_angle>
            </horizontal>
            <vertical>
              <samples>128</samples>
              <resolution>1</resolution>
              <min_angle>-0.785398</min_angle>
              <max_angle>0.785398</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.05</min>
            <max>100</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>
  </xacro:macro>
</robot>
