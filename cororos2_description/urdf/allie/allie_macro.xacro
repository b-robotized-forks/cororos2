<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="allie" params="prefix parent *origin">
    <!-- LINKS -->
    <!-- base footprint -->
    <link name="${prefix}base_footprint">
    </link>
    <!-- base link -->
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0 0 0.09" rpy="0 0 0" />
        <mass value="26.6" />
        <inertia ixx="0.387" ixy="0" ixz="0" iyy="0.790" iyz="0" izz="0.962" />
      </inertial>

      <!-- collisions -->
      <collision name="chassis_main_collision">
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <geometry>
          <box size="0.555 0.355 0.13" />
        </geometry>
      </collision>
      <collision name="emergency_stop_bottom_collision">
        <origin xyz="0.2 0.15 0.125" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.015" length="0.015" />
        </geometry>
      </collision>
      <collision name="emergency_stop_top_collision">
        <origin xyz="0.2 0.15 0.135" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.02" length="0.005" />
        </geometry>
      </collision>
      <collision name="wheel_mount_front_collision">
        <origin xyz="0.249 0 0.011" rpy="0 0 0" />
        <geometry>
          <box size="0.05 0.52 0.05" />
        </geometry>
      </collision>
      <collision name="wheel_mount_rear_collision">
        <origin xyz="-0.249 0 0.011" rpy="0 0 0" />
        <geometry>
          <box size="0.05 0.52 0.05" />
        </geometry>
      </collision>
      <!-- visuals -->
      <visual name="chassis_main_visual">
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <geometry>
          <box size="0.555 0.355 0.13" />
        </geometry>
        <material name="chassis_main_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0" />
        </material>
      </visual>
      <visual name="emergency_stop_bottom_visual">
        <origin xyz="0.2 0.15 0.125" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.015" length="0.015" />
        </geometry>
        <material name="emergency_stop_bottom_visual_mat">
          <color rgba="0.7059 0.7059 0.7059 1.0" />
        </material>
      </visual>
      <visual name="emergency_stop_top_visual">
        <origin xyz="0.2 0.15 0.135" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.02" length="0.005" />
        </geometry>
        <material name="emergency_stop_top_visual_mat">
          <color rgba="1.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <visual name="wheel_mount_front_visual">
        <origin xyz="0.249 0 0.011" rpy="0 0 0" />
        <geometry>
          <box size="0.05 0.52 0.05" />
        </geometry>
        <material name="wheel_mount_front_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0" />
        </material>
      </visual>
      <visual name="wheel_mount_rear_visual">
        <origin xyz="-0.249 0 0.011" rpy="0 0 0" />
        <geometry>
          <box size="0.05 0.52 0.05" />
        </geometry>
        <material name="wheel_mount_rear_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0" />
        </material>
      </visual>
      <visual name="ouster_deck_visual">
        <origin xyz="0.175 0.01 0.3625" rpy="0 0 0" />
        <geometry>
          <box size="0.24 0.18 0.012" />
        </geometry>
        <material name="ouster_deck_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam1_visual">
        <origin xyz="0.255 0.07 0.24375" rpy="0 0 0" />
        <geometry>
          <box size="0.018 0.018 0.2375" />
        </geometry>
        <material name="beam_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam2_visual">
        <origin xyz="0.255 -0.05 0.24375" rpy="0 0 0" />
        <geometry>
          <box size="0.018 0.018 0.2375" />
        </geometry>
        <material name="beam_visual_mat" />
      </visual>
      <visual name="beam3_visual">
        <origin xyz="0.095 0.07 0.24375" rpy="0 0 0" />
        <geometry>
          <box size="0.018 0.018 0.2375" />
        </geometry>
        <material name="beam_visual_mat" />
      </visual>
      <visual name="beam4_visual">
        <origin xyz="0.095 -0.05 0.24375" rpy="0 0 0" />
        <geometry>
          <box size="0.018 0.018 0.2375" />
        </geometry>
        <material name="beam_visual_mat" />
      </visual>
      <visual name="sensor_mast_visual">
        <origin xyz="0.255 0.07 1.01625" rpy="0 0 0" />
        <geometry>
          <box size="0.025 0.025 1.3175" />
        </geometry>
        <material name="sensor_mast_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="camera_plate_visual">
        <origin xyz="0.2745 0.01 1.548" rpy="0 0 0" />
        <geometry>
          <box size="0.095 0.16 0.012" />
        </geometry>
        <material name="camera_plate_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="gps_board_visual">
        <origin xyz="0.27 0.09 1.675" rpy="0 0 0" />
        <geometry>
          <box size="0.12 0.08 0.012" />
        </geometry>
        <material name="gps_board_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
    </link>
    <!-- drive wheels -->
    <!-- front left wheel -->
    <link name="${prefix}front_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="front_left_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="-1.5708 0 0" />
        <geometry>
          <cylinder radius="0.2" length="0.11" />
        </geometry>
      </collision>
      <visual name="front_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_description/meshes/allie/visual/wheel.dae" scale="1.1512 1.0 1.1512" />
        </geometry>
      </visual>
    </link>
    <!-- front right wheel -->
    <link name="${prefix}front_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="front_right_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder radius="0.2" length="0.11" />
        </geometry>
      </collision>
      <visual name="front_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_description/meshes/allie/visual/wheel.dae" scale="1.1512 1.0 1.1512" />
        </geometry>
      </visual>
    </link>
    <!-- rear left wheel -->
    <link name="${prefix}rear_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="rear_left_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="-1.5708 0 0" />
        <geometry>
          <cylinder radius="0.2" length="0.11" />
        </geometry>
      </collision>
      <visual name="rear_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_description/meshes/allie/visual/wheel.dae" scale="1.1512 1.0 1.1512" />
        </geometry>
      </visual>
    </link>
    <!-- rear right wheel -->
    <link name="${prefix}rear_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="rear_right_wheel_tire_collision">
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder radius="0.2" length="0.11" />
        </geometry>
      </collision>
      <visual name="rear_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_description/meshes/allie/visual/wheel.dae" scale="1.1512 1.0 1.1512" />
        </geometry>
      </visual>
    </link>
    <!-- sensor and light frames -->
    <!-- IMU frame -->
    <link name="${prefix}imu_sensor_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- GPS frame -->
    <link name="${prefix}gps_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <collision name="gps_base_collision">
        <origin xyz="0 0 0.012" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.028" length="0.024" />
        </geometry>
      </collision>
      <collision name="gps_cap_collision">
        <origin xyz="0 0 0.028" rpy="0 0 0" />
        <geometry>
          <sphere radius="0.016" />
        </geometry>
      </collision>
      <collision name="gps_antenna_tip_collision">
        <origin xyz="0 0 0.060" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.0035" length="0.024" />
        </geometry>
      </collision>
      <visual name="gps_base_visual">
        <origin xyz="0 0 0.012" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.028" length="0.024" />
        </geometry>
        <material name="gps_base_visual_mat">
          <color rgba="0.92 0.92 0.92 1.0" />
        </material>
      </visual>
      <visual name="gps_cap_visual">
        <origin xyz="0 0 0.028" rpy="0 0 0" />
        <geometry>
          <sphere radius="0.016" />
        </geometry>
        <material name="gps_cap_visual_mat">
          <color rgba="0.96 0.96 0.96 1.0" />
        </material>
      </visual>
      <visual name="gps_antenna_tip_visual">
        <origin xyz="0 0 0.060" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.0035" length="0.024" />
        </geometry>
        <material name="gps_antenna_tip_visual_mat">
          <color rgba="0.2 0.2 0.2 1.0" />
        </material>
      </visual>
    </link>
    <!-- front RGB-D camera frame -->
    <link name="${prefix}rgbd_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <collision name="d435i_realsense_camera_collision">
        <origin xyz="-0.017356 0 -0.009938" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_description/meshes/allie/visual/realsense_d435.dae" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <visual name="d435i_realsense_camera_visual">
        <origin xyz="-0.017356 0 -0.009938" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_description/meshes/allie/visual/realsense_d435.dae" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
    </link>
    <!-- Ouster sensor frame -->
    <link name="${prefix}ouster_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <collision name="ouster_body_collision">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.055" length="0.075" />
        </geometry>
      </collision>
      <collision name="ouster_window_collision">
        <origin xyz="0.042 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.008 0.09 0.035" />
        </geometry>
      </collision>
      <visual name="ouster_body_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.055" length="0.075" />
        </geometry>
        <material name="ouster_body_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0" />
        </material>
      </visual>
      <visual name="ouster_window_visual">
        <origin xyz="0.042 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.008 0.09 0.035" />
        </geometry>
        <material name="ouster_window_visual_mat">
          <color rgba="0.2 0.25 0.3 1.0" />
        </material>
      </visual>
    </link>
    <!-- Ouster internal IMU frame -->
    <link name="${prefix}ouster_imu_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- JOINTS -->
    <!-- base joints -->
    <!-- world to base footprint -->
    <xacro:if value="${parent != ''}">
      <joint name="${prefix}base_joint" type="fixed">
        <xacro:insert_block name="origin" />
        <parent link="${parent}" />
        <child link="${prefix}base_footprint" />
      </joint>
    </xacro:if>
    <!-- base footprint to base link -->
    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <parent link="${prefix}base_footprint" />
      <child link="${prefix}base_link" />
      <origin xyz="0 0 0.2" rpy="0 0 0" />
    </joint>
    <!-- wheel joints -->
    <!-- front left wheel joint -->
    <joint name="${prefix}front_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}front_left_wheel" />
      <origin xyz="0.25 0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- rear left wheel joint -->
    <joint name="${prefix}rear_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rear_left_wheel" />
      <origin xyz="-0.25 0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- rear right wheel joint -->
    <joint name="${prefix}rear_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rear_right_wheel" />
      <origin xyz="-0.25 -0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- front right wheel joint -->
    <joint name="${prefix}front_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}front_right_wheel" />
      <origin xyz="0.25 -0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- sensor and light frame joints -->
    <!-- base link to IMU frame -->
    <joint name="${prefix}base_link_to_imu_sensor_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}imu_sensor_link" />
      <origin xyz="0 0 -0.025" rpy="0 0 0" />
    </joint>
    <!-- base link to GPS frame -->
    <joint name="${prefix}base_link_to_gps_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}gps_link" />
      <origin xyz="0.27 0.09 1.681" rpy="0 0 0" />
    </joint>
    <!-- base link to front RGB-D camera frame -->
    <joint name="${prefix}base_link_to_rgbd_front_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rgbd_front_link" />
      <origin xyz="0.34 0.01 1.545" rpy="0 0.5236 0" />
    </joint>
    <!-- base link to Ouster sensor frame -->
    <joint name="${prefix}base_link_to_ouster_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}ouster_link" />
      <origin xyz="0.16 0 0.405" rpy="0 0 3.141592653589793" />
    </joint>
    <!-- Ouster sensor frame to Ouster IMU frame -->
    <joint name="${prefix}ouster_link_to_ouster_imu_link_joint" type="fixed">
      <parent link="${prefix}ouster_link" />
      <child link="${prefix}ouster_imu_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <!-- GAZEBO EXTENSIONS -->
    <!-- sensor definitions -->
    <gazebo reference="${prefix}imu_sensor_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <topic>imu</topic>
        <gz_frame_id>${prefix}imu_sensor_link</gz_frame_id>
        <imu>
          <enable_orientation>1</enable_orientation>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}gps_link">
      <sensor name="navsat" type="navsat">
        <always_on>1</always_on>
        <update_rate>5</update_rate>
        <topic>navsat</topic>
        <gz_frame_id>${prefix}gps_link</gz_frame_id>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}rgbd_front_link">
      <sensor name="rgbd_front" type="rgbd_camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <gz_frame_id>${prefix}rgbd_front_link</gz_frame_id>
        <camera name="rgbd_front">
          <horizontal_fov>1.50098</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>343.159</fx>
              <fy>343.159</fy>
              <cx>319.5</cx>
              <cy>179.5</cy>
              <s>0</s>
            </intrinsics>
          </lens>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
            <center>0.5 0.5</center>
          </distortion>
          <image>
            <width>640</width>
            <height>360</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>300</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.1</near>
              <far>10</far>
            </clip>
          </depth_camera>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}ouster_link">
      <sensor name="ouster_lidar" type="gpu_lidar">
        <visualize>0</visualize>
        <update_rate>10</update_rate>
        <gz_frame_id>${prefix}ouster_link</gz_frame_id>
        <lidar>
          <scan>
            <horizontal>
              <samples>1800</samples>
              <resolution>1</resolution>
              <min_angle>-3.1459</min_angle>
              <max_angle>3.1459</max_angle>
            </horizontal>
            <vertical>
              <samples>128</samples>
              <resolution>1</resolution>
              <min_angle>-0.785398</min_angle>
              <max_angle>0.785398</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.05</min>
            <max>100</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>
  </xacro:macro>
</robot>
