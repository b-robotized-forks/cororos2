<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="joe" params="prefix parent *origin">
    <link name="${prefix}base_footprint"/>

    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
        <mass value="26.6"/>
        <inertia ixx="0.387" ixy="0" ixz="0" iyy="0.790" iyz="0" izz="0.962"/>
      </inertial>
      <collision name="chassis_collision">
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
        <geometry>
          <box size="0.555 0.355 0.13"/>
        </geometry>
      </collision>
      <collision name="tower_collision">
        <origin xyz="0.13 0 0.27" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.34"/>
        </geometry>
      </collision>
      <visual name="chassis_main_visual">
        <origin xyz="0 0 0.07" rpy="0 0 0"/>
        <geometry>
          <box size="0.38 0.3 0.13"/>
        </geometry>
        <material name="chassis_main_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="wheel_mount_visual_front_left">
        <origin xyz="0.17 0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="wheel_mount_visual_front_left_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="wheel_mount_visual_front_right">
        <origin xyz="0.17 -0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="wheel_mount_visual_front_right_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="wheel_mount_visual_rear_left">
        <origin xyz="-0.17 0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="wheel_mount_visual_rear_left_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="wheel_mount_visual_rear_right">
        <origin xyz="-0.17 -0.12 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.06 0.02"/>
        </geometry>
        <material name="wheel_mount_visual_rear_right_mat">
          <color rgba="0.6 0.6 0.6 1.0"/>
        </material>
      </visual>
      <visual name="emergency_stop_bottom_visual">
        <origin xyz="0.11 0.125 0.145" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.015" length="0.015"/>
        </geometry>
        <material name="emergency_stop_bottom_visual_mat">
          <color rgba="0.7059 0.7059 0.7059 1.0"/>
        </material>
      </visual>
      <visual name="emergency_stop_top_visual">
        <origin xyz="0.11 0.125 0.155" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.005"/>
        </geometry>
        <material name="emergency_stop_top_visual_mat">
          <color rgba="1.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <visual name="plate1_visual">
        <origin xyz="0 0 0.435" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.005"/>
        </geometry>
        <material name="plate1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="plate2_visual">
        <origin xyz="0 0 0.325" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.005"/>
        </geometry>
        <material name="plate2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="plate3_visual">
        <origin xyz="0 0 0.135" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.2 0.005"/>
        </geometry>
        <material name="plate3_visual_mat">
          <color rgba="0.9412 0.9412 0.9412 1.0"/>
        </material>
      </visual>
      <visual name="beam1_visual">
        <origin xyz="0.091 0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="beam2_visual">
        <origin xyz="0.091 -0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="beam3_visual">
        <origin xyz="-0.091 0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam3_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
      <visual name="beam4_visual">
        <origin xyz="-0.091 -0.091 0.285" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.02 0.3"/>
        </geometry>
        <material name="beam4_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}front_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="front_left_wheel_collision">
        <origin xyz="0 0 0" rpy="-1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="front_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/wheel_left.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="front_left_wheel_axle_visual">
        <origin xyz="0 -0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="front_left_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}front_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="front_right_wheel_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="front_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/wheel_right.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="front_right_wheel_axle_visual">
        <origin xyz="0 0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="front_right_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rear_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="rear_left_wheel_collision">
        <origin xyz="0 0 0" rpy="-1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="rear_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/wheel_left.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="rear_left_wheel_axle_visual">
        <origin xyz="0 -0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="rear_left_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}rear_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="5.0"/>
        <inertia ixx="0.0153" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.0153"/>
      </inertial>
      <collision name="rear_right_wheel_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.1275" length="0.075"/>
        </geometry>
      </collision>
      <visual name="rear_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/wheel_right.dae" scale="1.22 1.22 1.71"/>
        </geometry>
      </visual>
      <visual name="rear_right_wheel_axle_visual">
        <origin xyz="0 0.055 0" rpy="1.5707963267948966 0 0"/>
        <geometry>
          <cylinder radius="0.007" length="0.05"/>
        </geometry>
        <material name="rear_right_wheel_axle_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>

    <link name="${prefix}imu_sensor_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
    </link>

    <link name="${prefix}rgbd_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
      <visual name="d435i_realsense_camera_visual">
        <origin xyz="-0.03 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/realsense_d435.dae" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
    </link>

    <link name="${prefix}front_laser_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="1e-6"/>
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/>
      </inertial>
      <visual name="vlp16_visual1">
        <origin xyz="0 0 -0.038" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/VLP16_base_1.dae" scale="1 1 1"/>
        </geometry>
      </visual>
      <visual name="vlp16_visual2">
        <origin xyz="0 0 -0.038" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/VLP16_base_2.dae" scale="1 1 1"/>
        </geometry>
      </visual>
      <visual name="vlp16_visual3">
        <origin xyz="0 0 -0.038" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://cororos2_joe_description/meshes/joe/visual/VLP16_scan.dae" scale="1 1 1"/>
        </geometry>
      </visual>
    </link>

    <link name="${prefix}light_front_link">
      <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="1e-6"/><inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/></inertial>
      <visual name="light_front_visual"><origin xyz="-0.03 0 0" rpy="0 0 0"/><geometry><box size="0.04 0.13 0.04"/></geometry><material name="light_front_visual_mat"><color rgba="0.0 0.0 0.0 1.0"/></material></visual>
    </link>
    <link name="${prefix}light_rear_link">
      <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="1e-6"/><inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/></inertial>
      <visual name="light_rear_visual"><origin xyz="0.03 0 0" rpy="0 0 0"/><geometry><box size="0.04 0.12 0.04"/></geometry><material name="light_rear_visual_mat"><color rgba="0.0 0.0 0.0 1.0"/></material></visual>
    </link>
    <link name="${prefix}light_left_link">
      <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="1e-6"/><inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/></inertial>
      <visual name="light_left_visual"><origin xyz="0 -0.03 0" rpy="0 0 0"/><geometry><box size="0.12 0.04 0.04"/></geometry><material name="light_left_visual_mat"><color rgba="0.0 0.0 0.0 1.0"/></material></visual>
    </link>
    <link name="${prefix}light_right_link">
      <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="1e-6"/><inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9"/></inertial>
      <visual name="light_right_visual"><origin xyz="0 0.03 0" rpy="0 0 0"/><geometry><box size="0.12 0.04 0.04"/></geometry><material name="light_right_visual_mat"><color rgba="0.0 0.0 0.0 1.0"/></material></visual>
    </link>

    <xacro:if value="${parent != ''}">
      <joint name="${prefix}base_joint" type="fixed">
        <xacro:insert_block name="origin"/>
        <parent link="${parent}"/>
        <child link="${prefix}base_footprint"/>
      </joint>
    </xacro:if>

    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <parent link="${prefix}base_footprint"/>
      <child link="${prefix}base_link"/>
      <origin xyz="0 0 0.1275" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}front_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}front_left_wheel"/>
      <origin xyz="0.17 0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="10" velocity="19.61"/>
    </joint>
    <joint name="${prefix}rear_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}rear_left_wheel"/>
      <origin xyz="-0.17 0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="10" velocity="19.61"/>
    </joint>
    <joint name="${prefix}rear_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}rear_right_wheel"/>
      <origin xyz="-0.17 -0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="10" velocity="19.61"/>
    </joint>
    <joint name="${prefix}front_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}front_right_wheel"/>
      <origin xyz="0.17 -0.21 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="10" velocity="19.61"/>
    </joint>

    <joint name="${prefix}base_link_to_imu_sensor_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}imu_sensor_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <joint name="${prefix}base_link_to_rgbd_front_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}rgbd_front_link"/>
      <origin xyz="0.11 0 1.5" rpy="0 0.5236 0"/>
    </joint>
    <joint name="${prefix}base_link_to_front_laser_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}front_laser_link"/>
      <origin xyz="0 0 0.365" rpy="0 0 0"/>
    </joint>
    <joint name="${prefix}base_link_to_light_front_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}light_front_link"/>
      <origin xyz="0.12 0 0.457" rpy="0 -1.5707963267948966 0"/>
    </joint>
    <joint name="${prefix}base_link_to_light_rear_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}light_rear_link"/>
      <origin xyz="-0.12 0 0.457" rpy="0 1.5707963267948966 0"/>
    </joint>
    <joint name="${prefix}base_link_to_light_left_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}light_left_link"/>
      <origin xyz="0 0.12 0.457" rpy="1.5707963267948966 0 0"/>
    </joint>
    <joint name="${prefix}base_link_to_light_right_link_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}light_right_link"/>
      <origin xyz="0 -0.12 0.457" rpy="-1.5707963267948966 0 0"/>
    </joint>
  </xacro:macro>
</robot>
