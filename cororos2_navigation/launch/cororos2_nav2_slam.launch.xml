<launch>
  <arg name="config_package"
       default="cororos2_navigation"
       description="Package with Nav2 and SLAM configuration used in the scenario." />
  <arg name="robot_model"
       default="cornelius"
       description="Robot model used to choose the default Nav2 config files.">
    <choice value="allie"/>
    <choice value="cornelius"/>
    <choice value="joe"/>
  </arg>
  <arg name="nav2_config_file"
       default=""
       description="Optional Nav2 config file name without the .yaml suffix." />
  <arg name="slam_config_file"
       default="cororos_slam"
       description="SLAM Toolbox config file basename without the .yaml suffix." />
  <arg name="use_sim_time"
       default="false"
       description="Use simulation time." />

  <arg name="scan_topic"
       default="/lidar/scan"
       description="LaserScan topic to use." />
  <arg name="use_twist_mux"
       default="true"
       description="Send Nav2 commands to twist_mux input instead of directly to the diff-drive controller." />
  <let name="selected_nav2_config_file"
       value="$(eval '\'$(var nav2_config_file)\' if \'$(var nav2_config_file)\' != \'\' else \'allie_nav2\' if \'$(var robot_model)\' == \'allie\' else \'cornelius_nav2\' if \'$(var robot_model)\' == \'cornelius\' else \'joe_nav2\'')" />
  <let name="selected_cmd_vel_out_topic"
       value="$(eval '\'cmd_vel_nav_safe\' if \'$(var use_twist_mux)\' == \'true\' else \'/diff_drive_controller/cmd_vel\'')" />

  <let name="slam_params" value="$(find-pkg-share $(var config_package))/config/$(var slam_config_file)" />
  <node name="slam_toolbox"
        pkg="slam_toolbox"
        exec="sync_slam_toolbox_node"
        output="screen">
    <param from="$(var slam_params).yaml" />
    <param name="use_sim_time" value="$(var use_sim_time)" />
    <param name="use_lifecycle_manager" value="true" />
    <param name="scan_topic" value="$(var scan_topic)" />
  </node>

  <node pkg="nav2_lifecycle_manager"
        exec="lifecycle_manager"
        name="lifecycle_manager_slam"
        output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)" />
    <param name="autostart" value="true" />
    <param name="node_names" value="['slam_toolbox']" />
  </node>

  <let name="nav2_params" value="$(find-pkg-share $(var config_package))/config/$(var selected_nav2_config_file).yaml" />
  <include file="$(find-pkg-share nav2_bringup)/launch/navigation_launch.py">
    <arg name="use_composition" value="False" />
    <arg name="params_file" value="$(var nav2_params)" />
    <arg name="use_sim_time" value="$(var use_sim_time)" />
    <arg name="selected_laser_scan_topic" value="$(var scan_topic)" />
    <arg name="selected_cmd_vel_out_topic" value="$(var selected_cmd_vel_out_topic)" />
  </include>
</launch>
