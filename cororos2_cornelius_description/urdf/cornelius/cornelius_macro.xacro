<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="cornelius" params="prefix parent *origin">
    <!-- LINKS -->
    <!-- base footprint -->
    <link name="${prefix}base_footprint">
    </link>
    <!-- base link -->
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="-0.000649 -0.084945 0.062329" rpy="0 0 0" />
        <mass value="21.8194" />
        <inertia ixx="0.615397" ixy="-0.0240585" ixz="-0.120749" iyy="1.75388" iyz="-0.0028322" izz="2.03641" />
      </inertial>
      <collision name="base_link_collision_top">
        <origin xyz="0 0 0.12" rpy="0 0 0" />
        <geometry>
          <box size="0.9874 0.5709 0.05" />
        </geometry>
      </collision>
      <collision name="base_link_collision_bottom">
        <origin xyz="0 0 0.046" rpy="0 0 0" />
        <geometry>
          <box size="0.80 0.5709 0.2" />
        </geometry>
      </collision>
      <collision name="base_link_collision_mid">
        <origin xyz="0 0 0.185625" rpy="0 0 0" />
        <geometry>
          <box size="0.78992 0.5709 0.12375" />
        </geometry>
      </collision>
      <collision name="tower_collision_1">
        <origin xyz="0.19 0 0.24" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.34" />
        </geometry>
      </collision>
      <visual name="body_visual">
        <origin xyz="0 0 -0.135" rpy="0 0 1.57" />
        <geometry>
          <mesh filename="package://cororos2_cornelius_description/meshes/cornelius/visual/hd2_marble_base_body_metric.dae" />
        </geometry>
        <material name="body_visual_mat">
          <color rgba="1.0 1.0 1.0 1.0" />
        </material>
      </visual>
      <visual name="plate1_visual">
        <origin xyz="0.19 0 0.38" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.005" />
        </geometry>
        <material name="plate1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="plate2_visual">
        <origin xyz="0.19 0 0.27" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.005" />
        </geometry>
        <material name="plate2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="plate3_visual">
        <origin xyz="0.19 0 0.08" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.005" />
        </geometry>
        <material name="plate3_visual_mat">
          <color rgba="0.9412 0.9412 0.9412 1.0" />
        </material>
      </visual>
      <visual name="beam1_visual">
        <origin xyz="0.281 0.091 0.23" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam2_visual">
        <origin xyz="0.281 -0.091 0.23" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam3_visual">
        <origin xyz="0.099 0.091 0.23" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam3_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam4_visual">
        <origin xyz="0.099 -0.091 0.23" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam4_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
    </link>
    <!-- wheel links -->
    <!-- left track body -->
    <link name="${prefix}left_track">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="4.0" />
        <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.18" iyz="0" izz="0.16" />
      </inertial>
      <collision name="left_track_box_collision">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.72 0.1 0.258" />
        </geometry>
      </collision>
      <visual name="left_track_body_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.72 0.1 0.258" />
        </geometry>
        <material name="left_track_body_visual_mat">
          <color rgba="0.08 0.08 0.08 1.0" />
        </material>
      </visual>
    </link>
    <!-- left rear drive roller -->
    <link name="${prefix}left_rear_drive_roller">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1.0" />
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.006" />
      </inertial>
      <collision name="left_rear_drive_roller_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
      </collision>
      <visual name="left_rear_drive_roller_visual">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
        <material name="left_rear_drive_roller_visual_mat">
          <color rgba="0.12 0.12 0.12 1.0" />
        </material>
      </visual>
    </link>
    <!-- left front idler roller -->
    <link name="${prefix}left_front_idler">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1.0" />
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.006" />
      </inertial>
      <collision name="left_front_idler_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
      </collision>
      <visual name="left_front_idler_visual">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
        <material name="left_front_idler_visual_mat">
          <color rgba="0.12 0.12 0.12 1.0" />
        </material>
      </visual>
    </link>
    <!-- right track body -->
    <link name="${prefix}right_track">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="4.0" />
        <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.18" iyz="0" izz="0.16" />
      </inertial>
      <collision name="right_track_box_collision">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.72 0.1 0.258" />
        </geometry>
      </collision>
      <visual name="right_track_body_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.72 0.1 0.258" />
        </geometry>
        <material name="right_track_body_visual_mat">
          <color rgba="0.08 0.08 0.08 1.0" />
        </material>
      </visual>
    </link>
    <!-- right rear drive roller -->
    <link name="${prefix}right_rear_drive_roller">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1.0" />
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.006" />
      </inertial>
      <collision name="right_rear_drive_roller_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
      </collision>
      <visual name="right_rear_drive_roller_visual">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
        <material name="right_rear_drive_roller_visual_mat">
          <color rgba="0.12 0.12 0.12 1.0" />
        </material>
      </visual>
    </link>
    <!-- right front idler roller -->
    <link name="${prefix}right_front_idler">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1.0" />
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.006" />
      </inertial>
      <collision name="right_front_idler_collision">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
      </collision>
      <visual name="right_front_idler_visual">
        <origin xyz="0 0 0" rpy="1.5707963267948966 0 0" />
        <geometry>
          <cylinder radius="0.129" length="0.1" />
        </geometry>
        <material name="right_front_idler_visual_mat">
          <color rgba="0.12 0.12 0.12 1.0" />
        </material>
      </visual>
    </link>
    <!-- sensor and light frames -->
    <!-- IMU frame -->
    <link name="${prefix}imu_sensor_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- GPS frame -->
    <link name="${prefix}gps_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- front RGB-D camera frame -->
    <link name="${prefix}rgbd_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="rgbd_front_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_cornelius_description/meshes/cornelius/visual/realsense_d435.dae" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
    </link>
    <!-- Ouster lidar frame -->
    <link name="${prefix}ouster_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="vlp16_visual1">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_cornelius_description/meshes/cornelius/visual/VLP16_base_1.dae" />
        </geometry>
        <material name="vlp16_visual1_mat">
          <color rgba="1.0 1.0 1.0 1.0" />
        </material>
      </visual>
      <visual name="vlp16_visual2">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_cornelius_description/meshes/cornelius/visual/VLP16_base_2.dae" />
        </geometry>
        <material name="vlp16_visual2_mat">
          <color rgba="1.0 1.0 1.0 1.0" />
        </material>
      </visual>
      <visual name="vlp16_visual3">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_cornelius_description/meshes/cornelius/visual/VLP16_scan.dae" />
        </geometry>
        <material name="vlp16_visual3_mat">
          <color rgba="1.0 1.0 1.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- Ouster IMU frame -->
    <link name="${prefix}ouster_imu_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- front light frame -->
    <link name="${prefix}light_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_front_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.04 0.13 0.04" />
        </geometry>
        <material name="light_front_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- rear light frame -->
    <link name="${prefix}light_rear_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_rear_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.04 0.12 0.04" />
        </geometry>
        <material name="light_rear_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- left light frame -->
    <link name="${prefix}light_left_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_left_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.12 0.04 0.04" />
        </geometry>
        <material name="light_left_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- right light frame -->
    <link name="${prefix}light_right_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_right_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.12 0.04 0.04" />
        </geometry>
        <material name="light_right_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>

    <!-- JOINTS -->
    <!-- base joints -->
    <xacro:if value="${parent != ''}">
      <joint name="${prefix}base_joint" type="fixed">
        <xacro:insert_block name="origin" />
        <parent link="${parent}" />
        <child link="${prefix}base_footprint" />
      </joint>
    </xacro:if>
    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <parent link="${prefix}base_footprint" />
      <child link="${prefix}base_link" />
      <origin xyz="0 0 0.129" rpy="0 0 0" />
    </joint>
    <!-- tracked side joints -->
    <joint name="${prefix}base_link_to_left_track_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}left_track" />
      <origin xyz="0 0.26 0" rpy="0 0 0" />
    </joint>
    <!-- Drive-relevant rear joint for the left track side. -->
    <joint name="${prefix}left_rear_drive_joint" type="revolute">
      <parent link="${prefix}base_link" />
      <child link="${prefix}left_rear_drive_roller" />
      <origin xyz="0.36 0.26 0" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit lower="-3.14159" upper="3.14159" effort="1.0" velocity="10.0" />
    </joint>
    <!-- Passive front idler for the left track side. -->
    <joint name="${prefix}left_front_idler_joint" type="revolute">
      <parent link="${prefix}base_link" />
      <child link="${prefix}left_front_idler" />
      <origin xyz="-0.36 0.26 0" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit lower="-3.14159" upper="3.14159" effort="1.0" velocity="10.0" />
      <mimic joint="${prefix}left_rear_drive_joint" multiplier="1.0" offset="0.0" />
    </joint>
    <joint name="${prefix}base_link_to_right_track_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}right_track" />
      <origin xyz="0 -0.26 0" rpy="0 0 0" />
    </joint>
    <!-- Drive-relevant rear joint for the right track side. -->
    <joint name="${prefix}right_rear_drive_joint" type="revolute">
      <parent link="${prefix}base_link" />
      <child link="${prefix}right_rear_drive_roller" />
      <origin xyz="0.36 -0.26 0" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit lower="-3.14159" upper="3.14159" effort="1.0" velocity="10.0" />
    </joint>
    <!-- Passive front idler for the right track side. -->
    <joint name="${prefix}right_front_idler_joint" type="revolute">
      <parent link="${prefix}base_link" />
      <child link="${prefix}right_front_idler" />
      <origin xyz="-0.36 -0.26 0" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <limit lower="-3.14159" upper="3.14159" effort="1.0" velocity="10.0" />
      <mimic joint="${prefix}right_rear_drive_joint" multiplier="1.0" offset="0.0" />
    </joint>
    <!-- sensor and light frame joints -->
    <joint name="${prefix}base_link_to_imu_sensor_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}imu_sensor_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}base_link_to_gps_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}gps_link" />
      <origin xyz="0.19 0 0.402" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}base_link_to_rgbd_front_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rgbd_front_link" />
      <origin xyz="0.28 0 0.353" rpy="0 0.46 0" />
    </joint>
    <joint name="${prefix}base_link_to_ouster_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}ouster_link" />
      <origin xyz="0.19 0 0.272" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}ouster_link_to_ouster_imu_link_joint" type="fixed">
      <parent link="${prefix}ouster_link" />
      <child link="${prefix}ouster_imu_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}base_link_to_light_front_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_front_link" />
      <origin xyz="0.28 0 0.402" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}base_link_to_light_rear_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_rear_link" />
      <origin xyz="0.10 0 0.402" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}base_link_to_light_left_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_left_link" />
      <origin xyz="0.19 0.09 0.402" rpy="0 0 0" />
    </joint>
    <joint name="${prefix}base_link_to_light_right_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_right_link" />
      <origin xyz="0.19 -0.09 0.402" rpy="0 0 0" />
    </joint>

    <!-- GAZEBO EXTENSIONS -->
    <!-- sensor definitions -->
    <gazebo reference="${prefix}imu_sensor_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <imu>
          <enable_orientation>0</enable_orientation>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}rgbd_front_link">
      <sensor name="rgbd_front" type="rgbd_camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <camera name="rgbd_front">
          <horizontal_fov>1.50098</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>343.159</fx>
              <fy>343.159</fy>
              <cx>319.5</cx>
              <cy>179.5</cy>
              <s>0</s>
            </intrinsics>
          </lens>
          <distortion>
