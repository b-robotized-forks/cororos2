<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:macro name="allie" params="prefix parent *origin">
    <!-- LINKS -->
    <!-- base footprint -->
    <link name="${prefix}base_footprint">
    </link>
    <!-- base link -->
    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0 0 0.09" rpy="0 0 0" />
        <mass value="26.6" />
        <inertia ixx="0.387" ixy="0" ixz="0" iyy="0.790" iyz="0" izz="0.962" />
      </inertial>
      <collision name="chassis_collision">
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <geometry>
          <box size="0.555 0.355 0.13" />
        </geometry>
      </collision>
      <collision name="tower_collision">
        <origin xyz="0.13 0 0.27" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.34" />
        </geometry>
      </collision>
      <visual name="chassis_main_visual">
        <origin xyz="0 0 0.05" rpy="0 0 0" />
        <geometry>
          <box size="0.555 0.355 0.13" />
        </geometry>
        <material name="chassis_main_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0" />
        </material>
      </visual>
      <visual name="emergency_stop_bottom_visual">
        <origin xyz="0.2 0.15 0.125" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.015" length="0.015" />
        </geometry>
        <material name="emergency_stop_bottom_visual_mat">
          <color rgba="0.7059 0.7059 0.7059 1.0" />
        </material>
      </visual>
      <visual name="emergency_stop_top_visual">
        <origin xyz="0.2 0.15 0.135" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.02" length="0.005" />
        </geometry>
        <material name="emergency_stop_top_visual_mat">
          <color rgba="1.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <visual name="wheel_mount_front_visual">
        <origin xyz="0.249 0 0.011" rpy="0 0 0" />
        <geometry>
          <box size="0.05 0.5 0.05" />
        </geometry>
        <material name="wheel_mount_front_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0" />
        </material>
      </visual>
      <visual name="wheel_mount_rear_visual">
        <origin xyz="-0.249 0 0.011" rpy="0 0 0" />
        <geometry>
          <box size="0.05 0.5 0.05" />
        </geometry>
        <material name="wheel_mount_rear_visual_mat">
          <color rgba="0.6 0.6 0.6 1.0" />
        </material>
      </visual>
      <visual name="plate1_visual">
        <origin xyz="0.13 0 0.42" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.005" />
        </geometry>
        <material name="plate1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="plate2_visual">
        <origin xyz="0.13 0 0.31" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.005" />
        </geometry>
        <material name="plate2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="plate3_visual">
        <origin xyz="0.13 0 0.12" rpy="0 0 0" />
        <geometry>
          <box size="0.2 0.2 0.005" />
        </geometry>
        <material name="plate3_visual_mat">
          <color rgba="0.9412 0.9412 0.9412 1.0" />
        </material>
      </visual>
      <visual name="beam1_visual">
        <origin xyz="0.221 0.091 0.27" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam1_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam2_visual">
        <origin xyz="0.221 -0.091 0.27" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam2_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam3_visual">
        <origin xyz="0.039 0.091 0.27" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam3_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
      <visual name="beam4_visual">
        <origin xyz="0.039 -0.091 0.27" rpy="0 0 0" />
        <geometry>
          <box size="0.02 0.02 0.3" />
        </geometry>
        <material name="beam4_visual_mat">
          <color rgba="0.7843 0.7843 0.7843 1.0" />
        </material>
      </visual>
    </link>
    <!-- drive wheels -->
    <!-- front left wheel -->
    <link name="${prefix}front_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="front_left_wheel_collision">
        <origin xyz="0 0 0" rpy="-1.5708 0 0" />
        <geometry>
          <cylinder radius="0.205" length="0.11" />
        </geometry>
      </collision>
      <visual name="front_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_allie_description/meshes/allie/visual/wheel.dae" scale="1.18 1.0 1.18" />
        </geometry>
      </visual>
    </link>
    <!-- front right wheel -->
    <link name="${prefix}front_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="front_right_wheel_collision">
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder radius="0.205" length="0.11" />
        </geometry>
      </collision>
      <visual name="front_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_allie_description/meshes/allie/visual/wheel.dae" scale="1.18 1.0 1.18" />
        </geometry>
      </visual>
    </link>
    <!-- rear left wheel -->
    <link name="${prefix}rear_left_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="rear_left_wheel_collision">
        <origin xyz="0 0 0" rpy="-1.5708 0 0" />
        <geometry>
          <cylinder radius="0.205" length="0.11" />
        </geometry>
      </collision>
      <visual name="rear_left_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_allie_description/meshes/allie/visual/wheel.dae" scale="1.18 1.0 1.18" />
        </geometry>
      </visual>
    </link>
    <!-- rear right wheel -->
    <link name="${prefix}rear_right_wheel">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="5.124" />
        <inertia ixx="0.0576" ixy="0" ixz="0" iyy="0.105" iyz="0" izz="0.0576" />
      </inertial>
      <collision name="rear_right_wheel_collision">
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder radius="0.205" length="0.11" />
        </geometry>
      </collision>
      <visual name="rear_right_wheel_tire_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_allie_description/meshes/allie/visual/wheel.dae" scale="1.18 1.0 1.18" />
        </geometry>
      </visual>
    </link>
    <!-- sensor and light frames -->
    <!-- IMU frame -->
    <link name="${prefix}imu_sensor_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- air pressure frame -->
    <link name="${prefix}air_pressure_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- magnetometer frame -->
    <link name="${prefix}magnetometer_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- GPS frame -->
    <link name="${prefix}gps_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- front RGB-D camera frame -->
    <link name="${prefix}rgbd_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="d435i_realsense_camera_visual">
        <origin xyz="-0.017356 0 -0.009938" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://cororos2_allie_description/meshes/allie/visual/realsense_d435.dae" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
    </link>
    <!-- front camera frame -->
    <link name="${prefix}camera_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="camera_front_visual">
        <origin xyz="-0.02 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.01 0.03 0.03" />
        </geometry>
        <material name="camera_front_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <visual name="camera_lens_front_visual">
        <origin xyz="-0.01 0 0" rpy="3.141593 1.570793 3.141593" />
        <geometry>
          <cylinder radius="0.005" length="0.011" />
        </geometry>
        <material name="camera_lens_front_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- rear camera frame -->
    <link name="${prefix}camera_rear_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="camera_rear_visual">
        <origin xyz="-0.02 0 0" rpy="0 0 -3.14159" />
        <geometry>
          <box size="0.01 0.03 0.03" />
        </geometry>
        <material name="camera_rear_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <visual name="camera_lens_rear_visual">
        <origin xyz="-0.01 0 0" rpy="3.141593 1.570793 0.000003" />
        <geometry>
          <cylinder radius="0.005" length="0.011" />
        </geometry>
        <material name="camera_lens_rear_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- left camera frame -->
    <link name="${prefix}camera_left_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="camera_left_visual">
        <origin xyz="-0.02 0 0" rpy="0 0 -1.5708" />
        <geometry>
          <box size="0.03 0.01 0.03" />
        </geometry>
        <material name="camera_left_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <visual name="camera_lens_left_visual">
        <origin xyz="-0.01 0 0" rpy="1.5708 0 -1.5708" />
        <geometry>
          <cylinder radius="0.005" length="0.011" />
        </geometry>
        <material name="camera_lens_left_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- right camera frame -->
    <link name="${prefix}camera_right_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="camera_right_visual">
        <origin xyz="-0.02 0 0" rpy="0 0 1.5708" />
        <geometry>
          <box size="0.03 0.01 0.03" />
        </geometry>
        <material name="camera_right_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
      <visual name="camera_lens_right_visual">
        <origin xyz="-0.01 0 0" rpy="1.5708 0 1.5708" />
        <geometry>
          <cylinder radius="0.005" length="0.011" />
        </geometry>
        <material name="camera_lens_right_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- Ouster sensor frame -->
    <link name="${prefix}ouster_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="ouster_body_visual">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.055" length="0.075" />
        </geometry>
        <material name="ouster_body_visual_mat">
          <color rgba="0.1 0.1 0.1 1.0" />
        </material>
      </visual>
      <visual name="ouster_window_visual">
        <origin xyz="0.042 0 0" rpy="0 0 0" />
        <geometry>
          <box size="0.008 0.09 0.035" />
        </geometry>
        <material name="ouster_window_visual_mat">
          <color rgba="0.2 0.25 0.3 1.0" />
        </material>
      </visual>
    </link>
    <!-- Ouster internal IMU frame -->
    <link name="${prefix}ouster_imu_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <!-- front light frame -->
    <link name="${prefix}light_front_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_front_visual">
        <origin xyz="0.002 0 0.03" rpy="3.141593 1.570793 3.141593" />
        <geometry>
          <box size="0.04 0.13 0.04" />
        </geometry>
        <material name="light_front_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- rear light frame -->
    <link name="${prefix}light_rear_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_rear_visual">
        <origin xyz="0.002 0 0.03" rpy="3.141593 -1.570793 3.141593" />
        <geometry>
          <box size="0.04 0.12 0.04" />
        </geometry>
        <material name="light_rear_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- left light frame -->
    <link name="${prefix}light_left_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_left_visual">
        <origin xyz="0 0.002 0.03" rpy="-1.5708 0 0" />
        <geometry>
          <box size="0.12 0.04 0.04" />
        </geometry>
        <material name="light_left_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>
    <!-- right light frame -->
    <link name="${prefix}light_right_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
      <visual name="light_right_visual">
        <origin xyz="0 -0.002 0.03" rpy="1.5708 0 0" />
        <geometry>
          <box size="0.12 0.04 0.04" />
        </geometry>
        <material name="light_right_visual_mat">
          <color rgba="0.0 0.0 0.0 1.0" />
        </material>
      </visual>
    </link>

    <!-- JOINTS -->
    <!-- base joints -->
    <!-- world to base footprint -->
    <xacro:if value="${parent != ''}">
      <joint name="${prefix}base_joint" type="fixed">
        <xacro:insert_block name="origin" />
        <parent link="${parent}" />
        <child link="${prefix}base_footprint" />
      </joint>
    </xacro:if>
    <!-- base footprint to base link -->
    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <parent link="${prefix}base_footprint" />
      <child link="${prefix}base_link" />
      <origin xyz="0 0 0.205" rpy="0 0 0" />
    </joint>
    <!-- wheel joints -->
    <!-- front left wheel joint -->
    <joint name="${prefix}front_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}front_left_wheel" />
      <origin xyz="0.25 0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- rear left wheel joint -->
    <joint name="${prefix}rear_left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rear_left_wheel" />
      <origin xyz="-0.25 0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- rear right wheel joint -->
    <joint name="${prefix}rear_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rear_right_wheel" />
      <origin xyz="-0.25 -0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- front right wheel joint -->
    <joint name="${prefix}front_right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link" />
      <child link="${prefix}front_right_wheel" />
      <origin xyz="0.25 -0.255 0" rpy="0 -0 0" />
      <axis xyz="0 1 0" />
      <limit effort="53.5" velocity="13.65" />
    </joint>
    <!-- sensor and light frame joints -->
    <!-- base link to IMU frame -->
    <joint name="${prefix}base_link_to_imu_sensor_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}imu_sensor_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <!-- base link to air pressure frame -->
    <joint name="${prefix}base_link_to_air_pressure_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}air_pressure_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <!-- base link to magnetometer frame -->
    <joint name="${prefix}base_link_to_magnetometer_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}magnetometer_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <!-- base link to GPS frame -->
    <joint name="${prefix}base_link_to_gps_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}gps_link" />
      <origin xyz="0.13 0 1.58" rpy="0 0 0" />
    </joint>
    <!-- base link to front RGB-D camera frame -->
    <joint name="${prefix}base_link_to_rgbd_front_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}rgbd_front_link" />
      <origin xyz="0.21 0 1.5" rpy="0 -0.5236 0" />
    </joint>
    <!-- base link to front camera frame -->
    <joint name="${prefix}base_link_to_camera_front_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}camera_front_link" />
      <origin xyz="0.24 0.06 0.405" rpy="0 0 0" />
    </joint>
    <!-- base link to rear camera frame -->
    <joint name="${prefix}base_link_to_camera_rear_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}camera_rear_link" />
      <origin xyz="0.02 0 0.405" rpy="0 0 3.14159" />
    </joint>
    <!-- base link to left camera frame -->
    <joint name="${prefix}base_link_to_camera_left_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}camera_left_link" />
      <origin xyz="0.13 0.11 0.405" rpy="0 0 1.5708" />
    </joint>
    <!-- base link to right camera frame -->
    <joint name="${prefix}base_link_to_camera_right_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}camera_right_link" />
      <origin xyz="0.13 -0.11 0.405" rpy="0 0 -1.5708" />
    </joint>
    <!-- base link to Ouster sensor frame -->
    <joint name="${prefix}base_link_to_ouster_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}ouster_link" />
      <origin xyz="0.13 0 0.35" rpy="0 -0 0" />
    </joint>
    <!-- Ouster sensor frame to Ouster IMU frame -->
    <joint name="${prefix}ouster_link_to_ouster_imu_link_joint" type="fixed">
      <parent link="${prefix}ouster_link" />
      <child link="${prefix}ouster_imu_link" />
      <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>
    <!-- base link to front light frame -->
    <joint name="${prefix}base_link_to_light_front_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_front_link" />
      <origin xyz="0.25 0 0.44" rpy="0 -1.5708 0" />
    </joint>
    <!-- base link to rear light frame -->
    <joint name="${prefix}base_link_to_light_rear_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_rear_link" />
      <origin xyz="0.01 0 0.442" rpy="0 1.5708 0" />
    </joint>
    <!-- base link to left light frame -->
    <joint name="${prefix}base_link_to_light_left_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_left_link" />
      <origin xyz="0.13 0.12 0.44" rpy="1.5708 0 0" />
    </joint>
    <!-- base link to right light frame -->
    <joint name="${prefix}base_link_to_light_right_link_joint" type="fixed">
      <parent link="${prefix}base_link" />
      <child link="${prefix}light_right_link" />
      <origin xyz="0.13 -0.12 0.44" rpy="-1.5708 0 0" />
    </joint>

    <!-- GAZEBO EXTENSIONS -->
    <!-- sensor definitions -->
    <gazebo reference="${prefix}imu_sensor_link">
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <imu>
          <enable_orientation>0</enable_orientation>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.009</stddev>
                <bias_mean>0.00075</bias_mean>
                <bias_stddev>0.005</bias_stddev>
                <dynamic_bias_stddev>0.00002</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>400.0</dynamic_bias_correlation_time>
                <precision>0.00025</precision>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0</mean>
                <stddev>0.021</stddev>
                <bias_mean>0.05</bias_mean>
                <bias_stddev>0.0075</bias_stddev>
                <dynamic_bias_stddev>0.000375</dynamic_bias_stddev>
                <dynamic_bias_correlation_time>175.0</dynamic_bias_correlation_time>
                <precision>0.005</precision>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}air_pressure_link">
      <sensor name="air_pressure" type="air_pressure">
        <always_on>1</always_on>
        <update_rate>20</update_rate>
        <air_pressure>
          <reference_altitude>0</reference_altitude>
          <noise type="gaussian">
            <mean>0.00000008</mean>
          </noise>
        </air_pressure>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}magnetometer_link">
      <sensor name="magnetometer" type="magnetometer">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <magnetometer>
          <x>
            <noise type="gaussian">
              <mean>0.000000080</mean>
              <bias_mean>0.000000400</bias_mean>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.000000080</mean>
              <bias_mean>0.000000400</bias_mean>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.000000080</mean>
              <bias_mean>0.000000400</bias_mean>
            </noise>
          </z>
        </magnetometer>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}rgbd_front_link">
      <sensor name="rgbd_front" type="rgbd_camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <camera name="rgbd_front">
          <horizontal_fov>1.50098</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>343.159</fx>
              <fy>343.159</fy>
              <cx>319.5</cx>
              <cy>179.5</cy>
              <s>0</s>
            </intrinsics>
          </lens>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
            <center>0.5 0.5</center>
          </distortion>
          <image>
            <width>640</width>
            <height>360</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>300</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.1</near>
              <far>10</far>
            </clip>
          </depth_camera>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}camera_front_link">
      <sensor name="camera_front" type="camera">
        <always_on>1</always_on>
        <update_rate>25</update_rate>
        <camera name="camera_front">
          <horizontal_fov>1.658</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>329.9</fx>
              <fy>329.9</fy>
              <cx>359.5</cx>
              <cy>539.5</cy>
              <s>0</s>
            </intrinsics>
          </lens>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
            <center>0.5 0.5</center>
          </distortion>
          <image>
            <width>720</width>
            <height>1080</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>300</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}camera_rear_link">
      <sensor name="camera_rear" type="camera">
        <always_on>1</always_on>
