            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}camera_right_link">
      <sensor name="camera_right" type="camera">
        <always_on>1</always_on>
        <update_rate>25</update_rate>
        <camera name="camera_front">
          <horizontal_fov>1.658</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>329.9</fx>
              <fy>329.9</fy>
              <cx>359.5</cx>
              <cy>539.5</cy>
              <s>0</s>
            </intrinsics>
          </lens>
          <distortion>
            <k1>0.0</k1>
            <k2>0.0</k2>
            <k3>0.0</k3>
            <p1>0.0</p1>
            <p2>0.0</p2>
            <center>0.5 0.5</center>
          </distortion>
          <image>
            <width>720</width>
            <height>1080</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
