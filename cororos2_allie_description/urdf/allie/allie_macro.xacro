            <mean>0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>
    <gazebo reference="${prefix}ouster_link">
      <sensor name="ouster_lidar" type="gpu_lidar">
        <visualize>0</visualize>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>1800</samples>
              <resolution>1</resolution>
              <min_angle>-3.1459</min_angle>
              <max_angle>3.1459</max_angle>
            </horizontal>
            <vertical>
              <samples>128</samples>
              <resolution>1</resolution>
              <min_angle>-0.785398</min_angle>
              <max_angle>0.785398</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.05</min>
            <max>100</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
      </sensor>
    </gazebo>
    <!-- light definitions -->
    <gazebo reference="${prefix}light_front_link">
      <light name="light_front" type="spot">
        <attenuation>
          <range>25</range>
          <linear>0</linear>
          <constant>0.1</constant>
          <quadratic>0.005</quadratic>
        </attenuation>
        <diffuse>0.8 0.8 0.5 1.0</diffuse>
        <specular>0.8 0.8 0.5 1</specular>
        <spot>
          <inner_angle>1.571</inner_angle>
          <outer_angle>2.1</outer_angle>
          <falloff>1</falloff>
        </spot>
        <direction>1 0 0</direction>
        <cast_shadows>1</cast_shadows>
      </light>
    </gazebo>
    <gazebo reference="${prefix}light_rear_link">
      <light name="light_rear" type="spot">
        <attenuation>
          <range>25</range>
          <linear>0</linear>
          <constant>0.1</constant>
          <quadratic>0.005</quadratic>
        </attenuation>
        <diffuse>0.8 0.8 0.5 1.0</diffuse>
        <specular>0.8 0.8 0.5 1</specular>
        <spot>
