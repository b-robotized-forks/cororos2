    </gazebo>
    <gazebo reference="${prefix}camera_left_link">
      <sensor name="camera_left" type="camera">
        <always_on>1</always_on>
        <update_rate>25</update_rate>
        <camera name="camera_front">
          <horizontal_fov>1.658</horizontal_fov>
          <lens>
            <intrinsics>
              <fx>329.9</fx>
              <fy>329.9</fy>
              <cx>359.5</cx>
              <cy>539.5</cy>
