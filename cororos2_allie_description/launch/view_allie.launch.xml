<launch>
  <arg name="description_package"
       default="cororos2_allie_description"
       description="Description package of the Allie mobile robot."/>

  <let name="robot_description_content" value="$(command '$(find-exec xacro) $(find-pkg-share $(var description_package))/urdf/allie.urdf.xacro')" />

  <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui"/>

  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="both">
    <param name="robot_description" value="$(var robot_description_content)" />
  </node>

  <node pkg="rviz2" exec="rviz2" output="log" args="-d $(find-pkg-share $(var description_package))/rviz/allie.rviz">
    <env name="LC_ALL" value="en_US.UTF-8"/>
  </node>
</launch>
