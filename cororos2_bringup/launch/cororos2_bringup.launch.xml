<launch>
  <!-- shared bringup implementation used by the public offline and hardware wrappers -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" output="both">
    <param name="robot_description" value="$(var robot_description_content)"/>
  </node>

  <node pkg="controller_manager" exec="ros2_control_node" name="b_controlled_box_cm" output="both">
    <remap from="~/robot_description" to="/robot_description"/>
    <param from="$(find-pkg-share $(var runtime_config_package))/config/$(var selected_controllers_file).yaml"/>
  </node>

  <node if="$(var rviz)" pkg="rviz2" exec="rviz2" output="log"
        args="-d $(find-pkg-share $(var description_package))/rviz/cororos2.rviz">
    <env name="LC_ALL" value="en_US.UTF-8"/>
  </node>

  <node pkg="controller_manager" exec="spawner"
        args="joint_state_broadcaster $(var robot_controller) --controller-manager /b_controlled_box_cm"/>
</launch>
