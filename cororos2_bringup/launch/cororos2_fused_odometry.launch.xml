<launch>
  <arg name="robot_model"
       default="allie"
       description="Robot model whose odometry and IMU inputs are fused. Choices are: [allie, cornelius, joe].">
    <choice value="allie"/>
    <choice value="cornelius"/>
    <choice value="joe"/>
  </arg>
  <arg name="runtime_config_package"
       default="cororos2_bringup"
       description="Package with the EKF configuration in the config folder."/>
  <arg name="fused_odometry_config_file"
       default="cororos_ekf"
       description="Fused odometry EKF YAML file basename without the .yaml suffix."/>
  <arg name="raw_odom_topic"
       default="/diff_drive_controller/odom"
       description="Raw wheel odometry topic used as EKF input."/>
  <arg name="use_fused_odometry"
       default="false"
       description="Fuse raw odometry and IMU with the EKF. When false, relay raw odometry as the filtered fallback."/>
  <arg name="imu_topic"
       default=""
       description="Optional IMU topic override. Defaults to /&lt;robot_model&gt;/imu/data."/>
  <arg name="filtered_odom_topic"
       default="/odometry/filtered"
       description="Filtered odometry topic published by robot_localization."/>
  <arg name="publish_tf"
       default="true"
       description="Publish the fused odom to base transform from the EKF."/>
  <arg name="use_sim_time"
       default="false"
       description="Use simulation time."/>

  <let name="selected_imu_topic"
       value="$(eval '\'$(var imu_topic)\' if \'$(var imu_topic)\' != \'\' else \'/$(var robot_model)/imu/data\'')" />

  <node if="$(var use_fused_odometry)"
        pkg="robot_localization"
        exec="ekf_node"
        name="ekf_filter_node"
        output="screen">
    <param from="$(find-pkg-share $(var runtime_config_package))/config/$(var fused_odometry_config_file).yaml"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="publish_tf" value="$(var publish_tf)"/>
    <param name="odom0" value="$(var raw_odom_topic)"/>
    <param name="imu0" value="$(var selected_imu_topic)"/>
    <remap from="odometry/filtered" to="$(var filtered_odom_topic)"/>
  </node>

  <node unless="$(var use_fused_odometry)"
        pkg="topic_tools"
        exec="relay"
        name="raw_odom_fallback_relay"
        output="screen">
    <param name="input_topic" value="$(var raw_odom_topic)"/>
    <param name="output_topic" value="$(var filtered_odom_topic)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>
</launch>
